{
  "project": {
    "name": "compass_app",
    "description": "Android-native compass MVP (Termux-first)",
    "rules": [
      ".agent/rules/CORE_RULES.md"
    ],
    "skills": [
      ".agent/skills"
    ]
  },
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--cdp-endpoint=http://localhost:9222",
        "--headless"
      ]
    }
  },
  "tools": {
    "sandbox": false
  }
}
